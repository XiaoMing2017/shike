.container {
  padding: 30rpx 30rpx 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #F3F6F8 0%, #EBF4F6 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

/* 1. 团队挑战概要卡片 */
.team-status-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(245, 243, 255, 0.9) 100%);
  border: 1rpx solid rgba(99, 102, 241, 0.15);
}

.team-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0F172A;
}

.team-desc {
  font-size: 22rpx;
  color: #64748B;
  margin-top: 6rpx;
}

.pot-badge {
  background-color: #6366F1;
  color: #FFFFFF;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  min-width: 100rpx;
}

.pot-val {
  font-size: 36rpx;
  font-weight: 800;
}

.pot-lbl {
  font-size: 16rpx;
  opacity: 0.8;
  margin-top: 2rpx;
}

.invite-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.invite-code-lbl {
  font-size: 24rpx;
  color: #475569;
}

.invite-code-lbl .code {
  font-weight: 700;
  color: #6366F1;
  background-color: #EEF2F6;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  margin-left: 8rpx;
  cursor: pointer;
}

.btn-share {
  background-color: #6366F1 !important;
  color: #FFFFFF !important;
  font-size: 22rpx !important;
  border-radius: 12rpx !important;
  padding: 6rpx 20rpx !important;
  margin: 0 !important;
  border: none !important;
  font-weight: 600 !important;
}

/* 2. 小队打卡榜 */
.leaderboard-section {
  margin-top: 10rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 20rpx;
}

.member-card {
  /* Inherits glass-card, removed solid white background override */
}

.rank-num {
  font-size: 28rpx;
  font-weight: 800;
  color: #94A3B8;
  width: 40rpx;
  text-align: center;
  margin-right: 16rpx;
}

.rank-num.top-rank {
  font-size: 34rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid #F1F5F9;
  margin-right: 20rpx;
}

.member-meta {
  flex: 1;
}

.member-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1E293B;
}

.progress-ticks {
  margin-top: 12rpx;
}

.tick {
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
  border: 1rpx solid #CBD5E1;
  margin-right: 8rpx;
  font-size: 20rpx;
  color: #94A3B8;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #F8FAFC;
}

.tick.checked {
  background-color: #E6FDF4;
  border-color: #10B981;
  color: #10B981;
  font-weight: 800;
}

.member-right {
  min-width: 140rpx;
}

.status-text {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status-text.checked-in {
  background-color: #E6FDF4;
  color: #10B981;
}

.status-text.pending {
  background-color: #FEF2F2;
  color: #EF4444;
}

.success-days {
  font-size: 20rpx;
  color: #64748B;
  margin-top: 8rpx;
}

.footer-actions {
  margin-top: 40rpx;
  gap: 16rpx;
}

.btn-action {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 24rpx;
  font-weight: 700;
  font-size: 28rpx;
  border: none;
  padding: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.btn-secondary {
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  color: #FFFFFF;
  box-shadow: 0 10rpx 20rpx rgba(99, 102, 241, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.btn-secondary:active {
  opacity: 0.95;
  transform: scale(0.97);
  box-shadow: 0 6rpx 12rpx rgba(99, 102, 241, 0.15);
}

.btn-quit {
  background: rgba(254, 242, 242, 0.65);
  color: #EF4444;
  border: 1rpx solid rgba(239, 68, 68, 0.25);
  box-shadow: 0 8rpx 20rpx rgba(239, 68, 68, 0.03);
}

.btn-quit:active {
  background: rgba(254, 242, 242, 0.95);
  transform: scale(0.97);
}

/* 无小队空状态样式 */
.welcome-header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.emoji-logo {
  font-size: 90rpx;
  margin-bottom: 20rpx;
}

.welcome-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #1E293B;
  margin-bottom: 16rpx;
}

.welcome-subtitle {
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.6;
  margin: 0 20rpx;
}

.action-card {
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1E293B;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #6366F1;
  padding-left: 16rpx;
}

.input-group {
  display: flex;
  width: 100%;
}

.invite-input {
  flex: 1;
  height: 88rpx;
  border: 1rpx solid #CBD5E1;
  border-radius: 16rpx 0 0 16rpx;
  padding: 0 24rpx;
  background-color: #F8FAFC;
  font-size: 28rpx;
}

.btn-join {
  background-color: #6366F1 !important;
  color: #FFFFFF !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  border-radius: 0 16rpx 16rpx 0 !important;
  font-size: 26rpx !important;
  font-weight: 700 !important;
  padding: 0 40rpx !important;
  margin: 0 !important;
  border: none !important;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 600;
}

.form-input {
  height: 88rpx;
  border: 1rpx solid #CBD5E1;
  border-radius: 16rpx;
  padding: 0 24rpx;
  background-color: #F8FAFC;
  font-size: 28rpx;
}

.picker-value {
  height: 88rpx;
  border: 1rpx solid #CBD5E1;
  border-radius: 16rpx;
  padding: 0 24rpx;
  background-color: #F8FAFC;
  font-size: 28rpx;
  color: #334155;
}

.arrow {
  font-size: 20rpx;
  color: #94A3B8;
}

.btn-create {
  width: 100% !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  font-size: 28rpx !important;
  font-weight: 700 !important;
  border-radius: 16rpx !important;
  background-color: #6366F1 !important;
  color: #FFFFFF !important;
  margin-top: 20rpx !important;
  border: none !important;
  text-align: center !important;
}
