.container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}

/* 1. 用户信息卡片 */
.user-info-card {
  background-color: #FFFFFF;
}

.user-info-card .avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #E2E8F0;
  margin-right: 30rpx;
}

.user-meta .nickname {
  font-size: 32rpx;
  font-weight: 800;
  color: #0F172A;
}

.user-meta .user-id {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

/* 2. 档案编辑表单 */
.profile-form-card {
  background-color: #FFFFFF;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #F1F5F9;
  padding-bottom: 16rpx;
}

.form-item {
  height: 96rpx;
  border-bottom: 1rpx solid #F8FAFC;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item .label {
  font-size: 26rpx;
  color: #475569;
}

.form-item .input {
  text-align: right;
  font-size: 26rpx;
  font-weight: 600;
  color: #1E293B;
  width: 200rpx;
}

.form-item .picker-val {
  font-size: 26rpx;
  font-weight: 600;
  color: #10B981;
}

/* 3. 计算结果看板 */
.result-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(240, 253, 250, 0.9) 100%);
  border: 1rpx solid rgba(16, 185, 129, 0.15);
}

.result-grid {
  width: 100%;
  margin: 10rpx 0 30rpx 0;
}

.grid-item {
  flex: 1;
}

.grid-item .val {
  font-size: 44rpx;
  font-weight: 800;
  color: #1E293B;
}

.grid-item .lbl {
  font-size: 20rpx;
  color: #64748B;
  margin-top: 6rpx;
}

.target-box {
  background-color: rgba(16, 185, 129, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.target-lbl {
  font-size: 22rpx;
  color: #047857;
  font-weight: 600;
}

.target-val {
  font-size: 40rpx;
  font-weight: 800;
  color: #047857;
  margin: 8rpx 0;
}

.formula-info {
  font-size: 18rpx;
  color: #059669;
  opacity: 0.8;
}
