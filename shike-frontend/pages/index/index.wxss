.container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}

/* 1. 今日热量大环形看板 */
.calorie-board {
  margin-top: 10rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(240, 253, 250, 0.9) 100%);
  border: 1rpx solid rgba(16, 185, 129, 0.15);
}

.calorie-ring {
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  border: 12rpx solid #10B981;
  box-shadow: 0 10rpx 30rpx rgba(16, 185, 129, 0.1);
  margin: 30rpx 0;
}

.ring-content {
  text-align: center;
}

.ring-label {
  font-size: 24rpx;
  color: #64748B;
  font-weight: 500;
}

.ring-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #0F172A;
  margin: 8rpx 0;
}

.ring-unit {
  font-size: 20rpx;
  color: #94A3B8;
}

.calorie-summary {
  width: 100%;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.summary-item {
  flex: 1;
}

.summary-val {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
}

.summary-lbl {
  font-size: 22rpx;
  color: #64748B;
  margin-top: 6rpx;
}

.divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #E2E8F0;
  align-self: center;
}

/* 2. 营养素看板 */
.nutrients-card {
  background: #FFFFFF;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 24rpx;
}

.nutrient-item {
  margin-bottom: 20rpx;
}

.nutrient-item:last-child {
  margin-bottom: 0;
}

.nutrient-info {
  margin-bottom: 8rpx;
}

.nutrient-name {
  font-size: 24rpx;
  color: #475569;
}

.nutrient-val {
  font-size: 24rpx;
  font-weight: 600;
  color: #1E293B;
}

/* 3. 三餐打卡卡片 */
.meal-section {
  margin-top: 10rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
  margin-bottom: 20rpx;
}

.meal-card {
  background-color: #FFFFFF;
}

.meal-icon-wrapper {
  font-size: 44rpx;
  margin-right: 20rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: #F8FAFC;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.meal-info-text {
  max-width: 360rpx;
}

.meal-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1E293B;
}

.meal-desc {
  font-size: 22rpx;
  color: #64748B;
  margin-top: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.meal-desc.empty {
  color: #94A3B8;
}

.meal-right {
  display: flex;
  align-items: center;
}

.meal-cal {
  font-size: 26rpx;
  font-weight: 700;
  color: #10B981;
  margin-right: 16rpx;
}

.btn-scan {
  background-color: #F1F5F9 !important;
  color: #475569 !important;
  font-weight: 600 !important;
  border-radius: 20rpx !important;
  padding: 6rpx 20rpx !important;
  margin: 0 !important;
  border: none !important;
  font-size: 24rpx !important;
}

.btn-scan:active {
  background-color: #E2E8F0 !important;
}

.scan-text {
  display: inline-block;
}
