.container {
  padding: 30rpx 40rpx 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #F3F6F8 0%, #EBF4F6 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

/* 0. 顶部导航/状态栏 */
.app-header {
  width: 100%;
  padding: 10rpx 0 30rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-icon-btn {
  font-size: 36rpx;
  width: 68rpx;
  height: 68rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 8rpx 24rpx rgba(148, 163, 184, 0.05);
}

.header-title-wrapper {
  text-align: center;
}

.header-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #1E293B;
  letter-spacing: 2rpx;
}

.header-date {
  font-size: 22rpx;
  color: #64748B;
  margin-top: 6rpx;
  font-weight: 600;
}

.header-avatar-btn {
  position: relative;
  width: 68rpx;
  height: 68rpx;
}

.header-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.avatar-dot {
  position: absolute;
  top: 0;
  right: 0;
  width: 12rpx;
  height: 12rpx;
  background-color: #EF4444;
  border-radius: 50%;
  border: 2rpx solid #FFFFFF;
}

/* 1. 今日热量大环形看板 */
.calorie-board-container {
  width: 100%;
  margin: 26rpx 0 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.calorie-ring-wrapper {
  width: 392rpx;
  height: 392rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.ring-outer-glow {
  position: absolute;
  width: 362rpx;
  height: 362rpx;
  border-radius: 181rpx;
  box-sizing: border-box;
  background: rgba(248, 252, 253, 0.82);
  box-shadow:
    0 26rpx 48rpx rgba(100, 116, 139, 0.12),
    0 0 42rpx rgba(255, 255, 255, 0.9);
  z-index: 1;
  overflow: hidden;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
}

.ring-glass-disc {
  position: absolute;
  width: 286rpx;
  height: 286rpx;
  border-radius: 143rpx;
  box-sizing: border-box;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(231, 240, 245, 0.72));
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  box-shadow:
    inset 18rpx 18rpx 34rpx rgba(148, 163, 184, 0.12),
    inset -18rpx -18rpx 34rpx rgba(255, 255, 255, 0.96),
    0 18rpx 46rpx rgba(100, 116, 139, 0.12);
  z-index: 2;
  overflow: hidden;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
}

.ring-inner-disc {
  position: absolute;
  width: 216rpx;
  height: 216rpx;
  border-radius: 108rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  box-shadow:
    inset 0 10rpx 18rpx rgba(255, 255, 255, 0.88),
    0 12rpx 34rpx rgba(148, 163, 184, 0.12);
  z-index: 3;
  overflow: hidden;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
}

.calorie-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 392rpx;
  height: 392rpx;
  z-index: 4;
  background: transparent !important;
}

.ring-content {
  position: absolute;
  z-index: 5;
  text-align: center;
  width: 220rpx;
  height: 220rpx;
  justify-content: center;
  background: transparent !important;
}

.ring-label {
  font-size: 28rpx;
  color: #334155;
  font-weight: 700;
  letter-spacing: 0;
  background: transparent !important;
}

.ring-value {
  font-size: 82rpx;
  line-height: 1;
  font-weight: 500;
  color: #171827;
  margin: 10rpx 0 8rpx 0;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  background: transparent !important;
}

.ring-unit {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 700;
  background: transparent !important;
}

.over-limit-lbl {
  color: #EF4444 !important;
}

.over-limit-val {
  color: #EF4444 !important;
}

.calorie-detail-text {
  font-size: 26rpx;
  color: #1F2937;
  margin-top: 18rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.bold-text {
  color: #111827;
  font-weight: 700;
}

/* 2. 三大营养素并列占比条 */
.nutrients-card {
  background: rgba(255, 255, 255, 0.65) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.6) !important;
  border-radius: 32rpx !important;
  padding: 24rpx 30rpx !important;
  margin-bottom: 40rpx !important;
  box-shadow: 0 10rpx 30rpx rgba(148, 163, 184, 0.03) !important;
}

.macronutrient-bar {
  display: flex;
  height: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background-color: #E2E8F0;
  margin-bottom: 24rpx;
  width: 100%;
}

.bar-segment {
  height: 100%;
  transition: width 0.3s ease;
}

.bar-segment.carbs {
  background: linear-gradient(90deg, #2DD4BF, #0D9488);
}

.bar-segment.protein {
  background: linear-gradient(90deg, #818CF8, #4F46E5);
}

.bar-segment.fat {
  background: linear-gradient(90deg, #C084FC, #9333EA);
}

.macronutrient-labels {
  width: 100%;
}

.label-item {
  display: flex;
  align-items: center;
}

.bullet {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.bullet.carbs {
  background-color: #0D9488;
}

.bullet.protein {
  background-color: #4F46E5;
}

.bullet.fat {
  background-color: #9333EA;
}

.label-text {
  display: flex;
  flex-direction: column;
}

.lbl-title {
  font-size: 20rpx;
  color: #94A3B8;
  font-weight: 600;
}

.lbl-val {
  font-size: 24rpx;
  font-weight: 700;
  color: #334155;
  margin-top: 4rpx;
}

.lbl-pct {
  font-size: 18rpx;
  color: #94A3B8;
  font-weight: 500;
  margin-left: 4rpx;
}

/* 3. 横向滑动三餐打卡记录卡片 */
.meal-section {
  width: 100%;
  margin-bottom: 40rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1E293B;
  letter-spacing: 1rpx;
}

.meal-scroll-row {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  width: 100%;
  box-sizing: border-box;
  padding: 10rpx 0;
}

.meal-card-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 196rpx;
  padding: 36rpx 16rpx 28rpx 16rpx;
  margin-right: 20rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 36rpx;
  flex-shrink: 0;
  box-shadow: 0 10rpx 30rpx rgba(148, 163, 184, 0.04);
  box-sizing: border-box;
  text-align: center;
}

.meal-card-item:last-child {
  margin-right: 0;
}

.meal-img-wrapper {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #F8FAFC;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.03);
  overflow: hidden;
}

.meal-card-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.meal-card-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 4rpx;
}

.meal-card-time {
  font-size: 20rpx;
  color: #94A3B8;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.meal-card-cal {
  font-size: 20rpx;
  font-weight: 700;
  color: #64748B;
  background-color: #F1F5F9;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.meal-card-cal.recorded {
  color: #10B981;
  background-color: #E6FDF4;
}
