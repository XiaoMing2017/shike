<view class="container">
  <!-- 0. 顶部导航/状态栏 -->
  <view class="app-header flex justify-between align-center">
    <view class="header-icon-btn">日</view>
    <view class="header-title-wrapper flex flex-col align-center">
      <text class="header-title">食刻</text>
      <text class="header-date">{{currentDateStr}}</text>
    </view>
    <view class="header-avatar-btn">
      <image class="header-avatar" src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=120" mode="aspectFill" />
      <view class="avatar-dot"></view>
    </view>
  </view>

  <!-- 1. 今日热量大环形看板 -->
  <view class="calorie-board-container align-center flex-col flex">
    <view class="calorie-ring-wrapper">
      <view class="ring-outer-glow"></view>
      <view class="ring-glass-disc"></view>
      <view class="ring-inner-disc"></view>
      <canvas type="2d" id="calorieCanvas" class="calorie-canvas" style="width: 196px; height: 196px;"></canvas>
      <view class="ring-content flex-col align-center flex">
        <text class="ring-label {{isOverLimit ? 'over-limit-lbl' : ''}}">{{ringLabel}}</text>
        <text class="ring-value {{isOverLimit ? 'over-limit-val' : ''}}">{{remainingCal}}</text>
        <text class="ring-unit">千卡</text>
      </view>
    </view>
    <view class="calorie-detail-text">
      已摄入：<text class="bold-text">{{consumedCal}}</text> / 目标：<text class="bold-text">{{targetCal}}</text>
    </view>
  </view>

  <!-- 2. 三大营养素并列占比条 -->
  <view class="glass-card nutrients-card">
    <view class="macronutrient-bar">
      <view class="bar-segment carbs" style="width: {{nutrients.carbsPercent}}%;"></view>
      <view class="bar-segment protein" style="width: {{nutrients.proteinPercent}}%;"></view>
      <view class="bar-segment fat" style="width: {{nutrients.fatPercent}}%;"></view>
    </view>

    <view class="macronutrient-labels flex justify-between">
      <view class="label-item flex align-center">
        <view class="bullet carbs"></view>
        <view class="label-text flex-col flex">
          <text class="lbl-title">碳水化合物</text>
          <text class="lbl-val">{{nutrients.carbs}}g <text class="lbl-pct">({{nutrients.carbsPercent}}%)</text></text>
        </view>
      </view>
      <view class="label-item flex align-center">
        <view class="bullet protein"></view>
        <view class="label-text flex-col flex">
          <text class="lbl-title">蛋白质</text>
          <text class="lbl-val">{{nutrients.protein}}g <text class="lbl-pct">({{nutrients.proteinPercent}}%)</text></text>
        </view>
      </view>
      <view class="label-item flex align-center">
        <view class="bullet fat"></view>
        <view class="label-text flex-col flex">
          <text class="lbl-title">脂肪</text>
          <text class="lbl-val">{{nutrients.fat}}g <text class="lbl-pct">({{nutrients.fatPercent}}%)</text></text>
        </view>
      </view>
    </view>
  </view>

  <!-- 3. 横向滑动三餐打卡记录卡片 -->
  <view class="meal-section">
    <view class="section-header flex justify-between align-center">
      <text class="section-title">今日三餐记录</text>
    </view>
    <scroll-view class="meal-scroll-row" scroll-x="true" enable-flex="true">
      <view class="meal-card-item" wx:for="{{meals}}" wx:key="type" catchtap="onScanMeal" data-type="{{item.type}}">
        <view class="meal-img-wrapper">
          <image class="meal-card-img" src="{{item.image}}" mode="aspectFill" />
        </view>
        <text class="meal-card-name">{{item.name}}</text>
        <text class="meal-card-time">{{item.time}}</text>
        <text class="meal-card-cal {{item.recorded ? 'recorded' : ''}}">{{item.recorded ? item.calories + '千卡' : '点击记录'}}</text>
      </view>
    </scroll-view>
  </view>
</view>
