<view class="container">
  <!-- 1. 今日热量大环形看板 -->
  <view class="glass-card calorie-board align-center flex-col flex">
    <view class="calorie-ring flex justify-center align-center">
      <view class="ring-content flex-col align-center flex">
        <text class="ring-label">剩余摄入</text>
        <text class="ring-value">{{remainingCal}}</text>
        <text class="ring-unit">千卡 (kcal)</text>
      </view>
    </view>
    <view class="calorie-summary flex justify-between">
      <view class="summary-item flex-col align-center flex">
        <text class="summary-val">{{targetCal}}</text>
        <text class="summary-lbl">目标热量</text>
      </view>
      <view class="divider"></view>
      <view class="summary-item flex-col align-center flex">
        <text class="summary-val">{{consumedCal}}</text>
        <text class="summary-lbl">已摄入</text>
      </view>
    </view>
  </view>

  <!-- 2. 三大营养素进度条 -->
  <view class="glass-card nutrients-card">
    <view class="card-title">宏量营养素 (g)</view>
    <view class="nutrient-item">
      <view class="nutrient-info flex justify-between">
        <text class="nutrient-name">碳水化合物</text>
        <text class="nutrient-val">{{nutrients.carbs}} / {{nutrients.targetCarbs}}g</text>
      </view>
      <progress percent="{{(nutrients.carbs/nutrients.targetCarbs)*100}}" stroke-width="6" active-color="#10B981" background-color="#E2E8F0" border-radius="3" />
    </view>
    <view class="nutrient-item">
      <view class="nutrient-info flex justify-between">
        <text class="nutrient-name">蛋白质</text>
        <text class="nutrient-val">{{nutrients.protein}} / {{nutrients.targetProtein}}g</text>
      </view>
      <progress percent="{{(nutrients.protein/nutrients.targetProtein)*100}}" stroke-width="6" active-color="#6366F1" background-color="#E2E8F0" border-radius="3" />
    </view>
    <view class="nutrient-item">
      <view class="nutrient-info flex justify-between">
        <text class="nutrient-name">脂肪</text>
        <text class="nutrient-val">{{nutrients.fat}} / {{nutrients.targetFat}}g</text>
      </view>
      <progress percent="{{(nutrients.fat/nutrients.targetFat)*100}}" stroke-width="6" active-color="#F59E0B" background-color="#E2E8F0" border-radius="3" />
    </view>
  </view>

  <!-- 3. 三餐打卡记录卡片 -->
  <view class="meal-section">
    <view class="section-title">今日三餐记录</view>
    <view class="glass-card meal-card flex align-center justify-between" wx:for="{{meals}}" wx:key="type">
      <view class="meal-left flex align-center">
        <view class="meal-icon-wrapper">{{item.icon}}</view>
        <view class="meal-info-text flex-col flex">
          <text class="meal-name">{{item.name}}</text>
          <text class="meal-desc" wx:if="{{item.recorded}}">{{item.desc}}</text>
          <text class="meal-desc empty" wx:else>暂无记录，随手拍一张吧</text>
        </view>
      </view>
      <view class="meal-right flex align-center">
        <text class="meal-cal" wx:if="{{item.recorded}}">+{{item.calories}} kcal</text>
        <button class="btn-scan" size="mini" catchtap="onScanMeal" data-type="{{item.type}}">
          <text class="scan-text">{{item.recorded ? '修改' : '记录'}}</text>
        </button>
      </view>
    </view>
  </view>
</view>
